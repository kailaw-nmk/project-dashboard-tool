# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Claude Code local settings (contains PC-specific paths)
.claude/settings.local.json

# MCP config (contains local file paths)
.mcp.json

# Playwright MCP temp files
.playwright-mcp/

# QA/Dev screenshots
/*.png

# Launcher scripts (local use only)
dev.bat

# typescript
*.tsbuildinfo
next-env.d.ts
